meta {
    format = 1,
}

enum Enum1: i16 {
    none = -1,
}

// Everything
struct Type1 {
	alpha: i8,
	alpha_beta: u8,
	alphaBeta: i16,
	a4: u16,
	a5: i32,
	a6: u32,
	a7: i64,
	a8: u64,
	a9: f32,
	a10: f64,
	n1: i8?,
	n2: u8?,
	n3: i16?,
	n4: u16?,
	n5: i16?,
	n6: u16?,
	n7: i32?,
	n8: u32?,
	n9: i64?,
	n10: u64?,
	s1: string,
	s2: string?,
	b1: bool,
	b2: bool?,
    e1: Enum1,
	e2: Enum1?,
	r1: [ string ],
	r2: [ string ]?,
	r3: [ string; 10],
	m1: { i32 : f64 },
	m2: { string : string },
	m3: { string : bool },
    t1: Type1,
    t2: Type1?
}
