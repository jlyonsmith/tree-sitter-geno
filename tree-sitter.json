{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "geno",
      "camelcase": "Geno",
      "title": "Geno",
      "scope": "source.geno",
      "file-types": ["geno"],
      "injection-regex": "^geno$",
      "class-name": "TreeSitterGeno"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Geno schema language",
    "authors": [
      {
        "name": "John Lyon-Smith",
        "email": "john@escapegallery.net",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/jlyonsmith/tree-sitter-geno",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
